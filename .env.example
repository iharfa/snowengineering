# ERPNext (leave blank to use local seed data fallback)
ERPNEXT_BASE_URL=https://erp.example.com
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
ERPNEXT_PRICE_LIST=Standard Selling

# Order routing
SNOW_ORDER_EMAIL=sales@snowengineering.mv
NEXT_PUBLIC_SNOW_WHATSAPP_NUMBER=9609690600

# Admin backend (/admin) — set a strong password to enable the built-in
# CRM / store dashboard. Leave blank to keep the admin area locked.
ADMIN_PASSWORD=

# Database (orders, leads, price-reveal analytics) — libSQL/SQLite.
# Leave blank for local dev: uses the file data/snow.db, no setup needed.
# For free hosting on Vercel, create a free Turso database (turso.tech) and set:
#   DATABASE_URL=libsql://<your-db>.turso.io
#   DATABASE_AUTH_TOKEN=<token from `turso db tokens create <your-db>`>
# The Vercel <-> Turso integration's TURSO_DATABASE_URL / TURSO_AUTH_TOKEN
# names are also picked up automatically.
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# GST
NEXT_PUBLIC_DEFAULT_GST_RATE=8

# Cloudflare Turnstile (optional bot protection on contact + order forms).
# Standalone widget — does NOT require the site to be hosted on Cloudflare.
# Leave blank to disable verification (forms still work). Set both to enforce.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Upstash Redis (optional). When set, rate limiting is global/durable across all
# serverless instances. When blank, falls back to per-instance in-memory limits.
# Easiest setup: Vercel → Integrations → Upstash (auto-populates these).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# SMTP (for /api/orders/email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Snow Engineering <no-reply@snowengineering.mv>
